# APNs credentials for VoIP / PushKit pushes (token-based auth using a .p8 key).
# Copy to .env and fill in, OR set these in docker-compose.yml.

# Path INSIDE the container to your AuthKey_XXXX.p8 (mount it via a volume).
APNS_KEY_PATH=/secrets/AuthKey.p8
# 10-char Key ID of that .p8 key (Apple Developer > Keys).
APNS_KEY_ID=ABCDE12345
# 10-char Apple Developer Team ID.
APNS_TEAM_ID=FGHIJ67890
# iOS app bundle id. The APNs topic sent for VoIP is "<bundle>.voip".
APNS_BUNDLE_ID=com.yourcompany.yourapp
# true  -> api.push.apple.com        (App Store / TestFlight builds)
# false -> api.sandbox.push.apple.com (Xcode debug builds)
APNS_PRODUCTION=false

# true -> DO NOT contact Apple; log the push and return success.
# Use this to bring the stack up locally without real credentials.
APNS_MOCK=true

PORT=5000
