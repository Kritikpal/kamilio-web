# Template for node_app/apns.env (which is gitignored because it holds secrets).
# Copy this file to apns.env and fill in real values:
#   cp node_app/apns.env.example node_app/apns.env

PORT=5000

# true  -> log the push and return success WITHOUT contacting Apple (local/dev)
# false -> actually send via APNs (requires the APNS_* values below + the .p8)
APNS_MOCK=true

# true  -> api.push.apple.com         (App Store / TestFlight builds)
# false -> api.sandbox.push.apple.com (Xcode debug builds)
APNS_PRODUCTION=false

# Path INSIDE the container to your AuthKey .p8 (mount it via the volume).
APNS_KEY_PATH=/secrets/AuthKey.p8
# 10-char Key ID of that .p8 key.
APNS_KEY_ID=ABCDE12345
# 10-char Apple Developer Team ID.
APNS_TEAM_ID=FGHIJ67890
# iOS app bundle id; the APNs topic sent is "<bundle>.voip".
APNS_BUNDLE_ID=com.yourcompany.yourapp
